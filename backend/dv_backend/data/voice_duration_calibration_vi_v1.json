      "difficulty": "normal",
      "enabled": true,
      "tags": [
        "long"
      ]
    },
    {
      "id": "vi_long_sentence_005",
      "text": "Khi quay clip mukbang, mình thường nói chậm hơn một chút để khán giả kịp theo dõi từng bước và cảm nhận được kết cấu của món ăn.",
      "category": "long_sentence",
      "difficulty": "normal",
      "enabled": true,
      "tags": [
        "long"
      ]
    },
    {
      "id": "vi_long_sentence_006",
      "text": "Bạn có thể thay thế sữa tươi bằng kem cooking nếu muốn sốt đặc hơn, nhưng nhớ hạ lửa để tránh bị vón cục khi sốt sôi quá mạnh.",
      "category": "long_sentence",
      "difficulty": "normal",
      "enabled": true,
      "tags": [
        "long"
      ]
    },
    {
      "id": "vi_long_sentence_007",
      "text": "Phần topping mình làm riêng để khi ăn kết hợp sẽ tạo cảm giác giòn tan, còn phần nước sốt thì nên đun sánh nhẹ trước khi rưới lên.",
      "category": "long_sentence",
      "difficulty": "normal",
      "enabled": true,
      "tags": [
        "long"
      ]
    },
    {
      "id": "vi_long_sentence_008",
      "text": "Với những ai ăn kiêng, bạn có thể giảm dầu và tăng rau củ, vẫn giữ được hương vị nhờ gia vị tỏi, gừng và một ít nước mắm.",
      "category": "long_sentence",
      "difficulty": "normal",
      "enabled": true,
      "tags": [
        "long"
      ]
    },
    {
      "id": "vi_long_sentence_009",
      "text": "Sau cùng, mình luôn nếm thử trước khi tắt bếp để điều chỉnh vị mặn, ngọt, chua cho phù hợp khẩu vị từng gia đình.",
      "category": "long_sentence",
      "difficulty": "normal",
      "enabled": true,
      "tags": [
        "long"
      ]
    },
    {
      "id": "vi_long_sentence_010",
      "text": "Clip này dài hơn bình thường vì mình muốn giải thích rõ từng bước để bạn có thể làm lại ngay tại nhà mà không bị thiếu chi tiết quan trọng.",
